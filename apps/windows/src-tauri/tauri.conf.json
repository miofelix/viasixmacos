{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ViaSix",
  "version": "0.1.1",
  "identifier": "dev.viasix.windows",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ViaSix",
        "width": 980,
        "height": 780,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ViaSix",
    "category": "Utility",
    "shortDescription": "IPv6-first Mihomo client",
    "longDescription": "ViaSix selects IPv6 proxy entry points and runs traffic through Mihomo.",
    "copyright": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": ["sidecar/*"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}
